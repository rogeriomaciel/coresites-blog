{
  "name": "coresites-blog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && bun run scripts/generate-og-images.ts && vite build && bun run scripts/prerender-seo.ts",
    "generate-sitemap": "bun run scripts/generate-sitemap.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "./deploy-local.sh",
    "n8n:push": "bun run scripts/sync-n8n.ts push",
    "n8n:pull": "bun run scripts/sync-n8n.ts pull",
    "publish:social": "bun run scripts/trigger-n8n.ts",
    "index:google": "bun run scripts/notify-google-indexing.ts"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
